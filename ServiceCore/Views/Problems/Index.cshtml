@model IEnumerable<ServiceCore.Models.Problem>
@{
    ViewData["Title"] = "Problem Management";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="mb-0">Problem Management</h1>
            <p class="text-muted small mb-0">Identify, analyze, and eliminate root causes of recurring incidents.</p>
        </div>
        <a href="@Url.Action("Create")" class="btn btn-primary">
            <i class="bi bi-plus-lg me-2"></i>New Problem Record
        </a>
    </div>

    <!-- Filters & Stats Hub -->
    <div class="row g-4 mb-4">
        <div class="col-12 col-md-3">
            <div class="card glass shadow-sm h-100 p-3 border-0">
                <div class="d-flex align-items-center gap-3">
                    <div class="avatar bg-primary bg-opacity-10 text-primary">
                        <i class="bi bi-shield-exclamation fs-4"></i>
                    </div>
                    <div>
                        <div class="h4 mb-0 fw-bold">@Model.Count(p => p.Status != "Closed")</div>
                        <div class="small text-muted fw-600">Active Problems</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-3">
            <div class="card glass shadow-sm h-100 p-3 border-0">
                <div class="d-flex align-items-center gap-3">
                    <div class="avatar bg-warning bg-opacity-10 text-warning">
                        <i class="bi bi-lightning-charge fs-4"></i>
                    </div>
                    <div>
                        <div class="h4 mb-0 fw-bold">@Model.Count(p => p.Priority == "High" || p.Priority == "Critical")</div>
                        <div class="small text-muted fw-600">High Priority</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-3">
            <div class="card glass shadow-sm h-100 p-3 border-0">
                <div class="d-flex align-items-center gap-3">
                    <div class="avatar bg-success bg-opacity-10 text-success">
                        <i class="bi bi-journal-check fs-4"></i>
                    </div>
                    <div>
                        <div class="h4 mb-0 fw-bold">@Model.Count(p => p.Status == "Known Error")</div>
                        <div class="small text-muted fw-600">Known Errors (KEDB)</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-3">
            <div class="card glass shadow-sm h-100 p-3 border-0">
                <div class="d-flex align-items-center gap-3">
                    <div class="avatar bg-info bg-opacity-10 text-info">
                        <i class="bi bi-link-45deg fs-4"></i>
                    </div>
                    <div>
                        <div class="h4 mb-0 fw-bold">@Model.Sum(p => p.LinkedIncidents.Count)</div>
                        <div class="small text-muted fw-600">Linked Incidents</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Main List Card -->
    <div class="card glass-elevated border-0 shadow-sm overflow-hidden">
        <div class="card-header bg-white py-3">
            <form method="get" class="row g-3 align-items-center">
                <div class="col-auto">
                    <div class="input-group">
                        <span class="input-group-text bg-transparent border-end-0"><i class="bi bi-search"></i></span>
                        <input type="text" name="search" class="form-control border-start-0 ps-0" placeholder="Search problems..." value="@ViewBag.Search">
                    </div>
                </div>
                <div class="col-auto">
                    <select name="status" class="form-select" onchange="this.form.submit()">
                        <option value="">All Statuses</option>
                        <option value="Open" selected="@(ViewBag.Status == "Open")">Open</option>
                        <option value="Under Investigation" selected="@(ViewBag.Status == "Under Investigation")">Under Investigation</option>
                        <option value="Root Cause Identified" selected="@(ViewBag.Status == "Root Cause Identified")">Root Cause Identified</option>
                        <option value="Known Error" selected="@(ViewBag.Status == "Known Error")">Known Error</option>
                        <option value="Resolved" selected="@(ViewBag.Status == "Resolved")">Resolved</option>
                        <option value="Closed" selected="@(ViewBag.Status == "Closed")">Closed</option>
                    </select>
                </div>
                <div class="col-auto">
                    <button type="submit" class="btn btn-outline-secondary">Filter</button>
                </div>
            </form>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4">Problem ID</th>
                            <th>Title</th>
                            <th>Status</th>
                            <th>Priority</th>
                            <th>Category</th>
                            <th>Assigned To</th>
                            <th>Incidents</th>
                            <th class="pe-4 text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var problem in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold">#PROB-@problem.Id.ToString("D4")</td>
                                <td>
                                    <div class="fw-600">@problem.Title</div>
                                    <div class="small text-muted text-truncate" style="max-width: 300px;">@problem.Description</div>
                                </td>
                                <td>
                                    @{
                                        var statusClass = problem.Status switch
                                        {
                                            "Open" => "bg-primary",
                                            "Under Investigation" => "bg-warning",
                                            "Known Error" => "bg-success",
                                            "Resolved" => "bg-info",
                                            "Closed" => "bg-secondary",
                                            _ => "bg-primary"
                                        };
                                    }
                                    <span class="badge @statusClass bg-opacity-10 text-@statusClass.Replace("bg-", "") border border-@statusClass.Replace("bg-", "") border-opacity-25 px-2">
                                        @problem.Status
                                    </span>
                                </td>
                                <td>
                                    @{
                                        var priorityClass = problem.Priority switch
                                        {
                                            "Critical" => "text-danger",
                                            "High" => "text-warning",
                                            "Medium" => "text-primary",
                                            _ => "text-muted"
                                        };
                                    }
                                    <span class="@priorityClass fw-600"><i class="bi bi-circle-fill me-1 smaller"></i>@problem.Priority</span>
                                </td>
                                <td>@problem.Category?.Name</td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="avatar avatar-xs bg-brand-blue text-primary smaller fw-bold">
                                            @(problem.AssignedTo?.Name?.Substring(0, 1) ?? "?")
                                        </div>
                                        <span class="small fw-500">@(problem.AssignedTo?.Name ?? "Unassigned")</span>
                                    </div>
                                </td>
                                <td>
                                    <span class="badge bg-light text-dark border">
                                        <i class="bi bi-link me-1"></i>@problem.LinkedIncidents.Count
                                    </span>
                                </td>
                                <td class="pe-4 text-end">
                                    <a href="@Url.Action("Details", new { id = problem.Id })" class="btn btn-sm btn-outline-primary px-3">
                                        <i class="bi bi-eye me-1"></i>Analyze
                                    </a>
                                </td>
                            </tr>
                        }
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="8" class="text-center py-5 text-muted">
                                    <i class="bi bi-search fs-1 d-block mb-3 opacity-25"></i>
                                    No problem records found match your search criteria.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
