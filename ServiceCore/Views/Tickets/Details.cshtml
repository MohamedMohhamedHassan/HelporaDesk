@model ServiceCore.Models.Ticket

@{
    ViewData["Title"] = "Ticket Details";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Ticket #@Model.Id - @Model.Subject</h2>
        <a href="@Url.Action("Index")" class="btn btn-outline-secondary">← Back to List</a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    <div class="row">
        <!-- Left Column: Ticket Details -->
        <div class="col-lg-8">
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0">Ticket Information</h5>
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <strong>Status:</strong>
                            <span class="badge bg-primary">@Model.Status?.Name</span>
                        </div>
                        <div class="col-md-6">
                            <strong>Priority:</strong>
                            <span class="badge bg-warning">@Model.Priority?.Name</span>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <strong>Category:</strong> @Model.Category?.Name
                        </div>
                        <div class="col-md-6">
                            <strong>Created:</strong> @Model.CreatedAt.ToString("MMM dd, yyyy HH:mm")
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <strong>Requester:</strong> @Model.Requester?.Name
                        </div>
                        <div class="col-md-6">
                            <strong>Assigned To:</strong> @(Model.Assigned?.Name ?? "Unassigned")
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-12">
                            <strong>Related Asset:</strong>
                            @if (Model.AssetId.HasValue && Model.Asset != null)
                            {
                                <a href="@Url.Action("Details", "Assets", new { id = Model.AssetId })" class="badge bg-secondary text-decoration-none">
                                    <i class="bi bi-pc-display me-1"></i> @Model.Asset.Name (@Model.Asset.Tag)
                                </a>
                            }
                            else
                            {
                                <span class="text-muted small">None</span>
                            }
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <strong>Due Date:</strong>
                            <span class="@(Model.DueDate < DateTime.Now ? "text-danger fw-bold" : "text-dark")">
                                @(Model.DueDate?.ToString("MMM dd, yyyy HH:mm") ?? "N/A")
                                @if (Model.DueDate < DateTime.Now && (Model.Status?.Name != "Closed" &&
                                                                Model.Status?.Name != "Resolved"))
                                {
                                    <i class="bi bi-exclamation-triangle-fill ms-1" title="Overdue"></i>
                                }
                            </span>
                        </div>
                        <div class="col-md-6">
                            <strong>Resolution Date:</strong> @(Model.ResolutionDate?.ToString("MMM dd, yyyy HH:mm") ??
                                                        "N/A")
                        </div>
                    </div>
                    <div class="mb-3">
                        <strong>Description:</strong>
                        <p class="mt-2">@Model.Description</p>
                    </div>
                </div>
            </div>

            <!-- Chat/Comments Section -->
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">
                        <i class="bi bi-chat-dots me-2"></i>Comments & Responses
                    </h5>
                </div>
                <div class="card-body">
                    <!-- Comments List -->
                    @{
                        var currentUserId = 0;
                        int.TryParse(User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value, out
                    currentUserId);
                    }
                    <div class="chat mb-4" style="max-height: 400px; overflow-y: auto;">
                        @if (Model.Comments != null && Model.Comments.Any())
                        {
                            foreach (var comment in Model.Comments.OrderBy(c => c.CreatedAt))
                            {
                                var isMe = comment.UserId == currentUserId;
                                <div class="chat-msg mb-3 @(isMe ? "me" : "")">
                                    <div class="chat-msg__meta mb-1">
                                        <strong>@comment.User?.Name</strong>
                                        <small class="text-muted ms-2">@comment.CreatedAt.ToString("MMM dd, yyyy HH:mm")</small>
                                    </div>
                                    <div class="chat-bubble">
                                        @comment.Content
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <p class="text-muted text-center py-4">No comments yet. Be the first to respond!</p>
                        }
                    </div>

                    <!-- Add Comment Form -->
                    <form method="post" action="@Url.Action("AddComment")">
                        <input type="hidden" name="ticketId" value="@Model.Id" />
                        <div class="mb-3">
                            <label for="content" class="form-label">Add Response</label>
                            <textarea          class="form-control" id="content" name="content" rows="3"
                                               placeholder="Type your response here..." required></textarea>
                        </div>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-send me-2"></i>Send Response
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <!-- Right Column: Quick Actions -->
        <div class="col-lg-4">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Quick Actions</h5>
                </div>
                <div class="card-body">
                    <div class="d-flex gap-2 mb-2">
                        <a href="@Url.Action("Edit", new { id = Model.Id })" class="btn btn-outline-secondary w-100">
                            <i class="bi bi-pencil me-1"></i>Edit
                        </a>
                        <a href="@Url.Action("Create", "Problems", new { title = Model.Subject, description = Model.Description, categoryId = Model.CategoryId })" class="btn btn-outline-warning w-100">
                            <i class="bi bi-shield-exclamation me-1"></i>Create Problem
                        </a>
                    </div>

                    @if (Model.Status?.Name != "Closed" && Model.Status?.Name != "Resolved")
                    {
                        <form method="post" action="/Approvals/RequestApproval" class="mb-2">
                            <input type="hidden" name="type" value="Ticket_Resolution" />
                            <input type="hidden" name="relatedId" value="@Model.Id" />
                            <input type="hidden" name="subject" value="Approval for Ticket #@Model.Id" />
                            <input type="hidden" name="description"
                                   value="Requesting formal approval to resolve: @Model.Subject" />
                            <button type="submit" class="btn btn-primary w-100">
                                <i class="bi bi-check-circle me-2"></i>Request Approval
                            </button>
                        </form>
                    }

                    <form method="post" action="@Url.Action("Delete", new { id = Model.Id })" class="d-inline w-100">
                        <button type="submit" class="btn btn-outline-danger w-100"
                                onclick="return confirm('Are you sure you want to delete this ticket?')">
                            <i class="bi bi-trash me-2"></i>Delete Ticket
                        </button>
                    </form>
                </div>
            </div>

            <div class="card mt-3">
                <div class="card-header">
                    <h5 class="mb-0">Activity</h5>
                </div>
                <div class="card-body">
                    <small class="text-muted">
                        <strong>Last Updated:</strong><br>
                        @((Model.UpdatedAt ?? Model.CreatedAt).ToString("MMM dd, yyyy HH:mm"))
                    </small>
                </div>
            </div>

            <!-- Ticket Links -->
            <div class="card mt-3">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Linked Tickets</h5>
                    <button class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#modalLinkTicket">
                        <i class="bi bi-link-45deg"></i> Link
                    </button>
                </div>
                <div class="card-body p-0">
                    <div class="list-group list-group-flush">
                        @foreach (var link in Model.LinkedFrom)
                        {
                            <div class="list-group-item d-flex justify-content-between align-items-center">
                                <div class="text-truncate" style="max-width: 70%;">
                                    <small class="text-muted d-block">@link.LinkType →</small>
                                    <a href="@Url.Action("Details", new { id = link.TargetTicketId })" class="text-decoration-none fw-600">
                                        #@link.TargetTicketId - @link.TargetTicket?.Subject
                                    </a>
                                </div>
                                <form method="post" action="@Url.Action("RemoveLink")" class="d-inline">
                                    <input type="hidden" name="linkId" value="@link.Id" />
                                    <input type="hidden" name="returnTicketId" value="@Model.Id" />
                                    <button type="submit" class="btn btn-sm btn-link text-danger p-0" onclick="return confirm('Remove link?')">
                                        <i class="bi bi-x-circle"></i>
                                    </button>
                                </form>
                            </div>
                        }
                        @foreach (var link in Model.LinkedTo)
                        {
                            <div class="list-group-item d-flex justify-content-between align-items-center">
                                <div class="text-truncate" style="max-width: 70%;">
                                    <small class="text-muted d-block">← @link.LinkType (from)</small>
                                    <a href="@Url.Action("Details", new { id = link.SourceTicketId })" class="text-decoration-none fw-600">
                                        #@link.SourceTicketId - @link.SourceTicket?.Subject
                                    </a>
                                </div>
                                <form method="post" action="@Url.Action("RemoveLink")" class="d-inline">
                                    <input type="hidden" name="linkId" value="@link.Id" />
                                    <input type="hidden" name="returnTicketId" value="@Model.Id" />
                                    <button type="submit" class="btn btn-sm btn-link text-danger p-0" onclick="return confirm('Remove link?')">
                                        <i class="bi bi-x-circle"></i>
                                    </button>
                                </form>
                            </div>
                        }
                        @if (!Model.LinkedTo.Any() && !Model.LinkedFrom.Any())
                        {
                            <div class="p-3 text-center text-muted small">No linked tickets.</div>
                        }
                    </div>
                </div>
            </div>

            <!-- Related Solutions -->
            <div class="card mt-3 border-success">
                <div class="card-header bg-success bg-opacity-10">
                    <h6 class="mb-0 text-success">
                        <i class="bi bi-lightbulb me-2"></i>Related Solutions
                    </h6>
                </div>
                <div class="card-body">
                    @{
                        var relatedSolutions = ViewBag.RelatedSolutions as List<ServiceCore.Models.Solution>;

                        if (relatedSolutions != null && relatedSolutions.Any())
                        {
                            <small class="text-muted d-block mb-3">Suggested solutions for this ticket</small>
                            <div class="list-group list-group-flush">
                                @foreach (var solution in relatedSolutions)
                                {
                                    <a href="/Solutions/Details/@solution.Id"
                                           class="list-group-item list-group-item-action border-0 px-0 py-2" target="_blank">
                                        <div class="d-flex w-100 justify-content-between align-items-start">
                                            <div style="flex: 1; min-width: 0;">
                                                <div class="mb-1 small fw-bold text-truncate">
                                                    @solution.Title
                                                </div>
                                                <small class="text-muted">
                                                    <i class="bi bi-tag me-1"></i>@solution.Topic?.Name
                                                </small>
                                            </div>
                                            <span class="badge bg-success bg-opacity-10 text-success small ms-2">
                                                <i class="bi bi-eye"></i> @solution.Views
                                            </span>
                                        </div>
                                    </a>
                                }
                            </div>
                            <a href="/Solutions" class="btn btn-sm btn-outline-success w-100 mt-3">
                                <i class="bi bi-search"></i> Browse All
                            </a>
                        }
                        else
                        {
                            <p class="text-muted small mb-3">
                                <i class="bi bi-info-circle me-1"></i>
                                No related solutions found.
                            </p>
                            <a href="/Solutions/Create?ticketId=@Model.Id&title=@Uri.EscapeDataString(Model.Subject)"
                                   class="btn btn-sm btn-outline-success w-100">
                                <i class="bi bi-plus-circle"></i> Create Solution
                            </a>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Link Ticket Modal -->
<div class="modal fade" id="modalLinkTicket" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Link to Another Ticket</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" action="@Url.Action("LinkTickets")">
                <input type="hidden" name="sourceTicketId" value="@Model.Id" />
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Search Ticket (ID or Subject)</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-search"></i></span>
                            <input type="text" id="ticketSearchInput" class="form-control" placeholder="Type to search..." autocomplete="off" />
                        </div>
                        <div id="ticketSearchResults" class="list-group mt-2 border rounded shadow-sm" style="display:none; max-height: 200px; overflow-y: auto;">
                            <!-- Results will be injected here -->
                        </div>
                        <input type="hidden" name="targetTicketId" id="selectedTargetTicketId" required />
                    </div>
                    
                    <div id="selectedTicketDisplay" class="alert alert-info py-2 small" style="display:none;">
                        Selected: <span id="selectedTicketText"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Relationship Type</label>
                        <select name="linkType" class="form-select">
                            <option value="Related">Relates to</option>
                            <option value="Duplicate">Is duplicate of</option>
                            <option value="Blocks">Blocks</option>
                            <option value="BlockedBy">Is blocked by</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary" id="btnSubmitLink" disabled>Link Ticket</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const searchInput = document.getElementById('ticketSearchInput');
        const resultsDiv = document.getElementById('ticketSearchResults');
        const selectedIdInput = document.getElementById('selectedTargetTicketId');
        const selectedDisplay = document.getElementById('selectedTicketDisplay');
        const selectedText = document.getElementById('selectedTicketText');
        const submitBtn = document.getElementById('btnSubmitLink');
        let searchTimeout;

        searchInput.addEventListener('input', function() {
            const query = this.value;
            clearTimeout(searchTimeout);
            
            if (query.length < 2) {
                resultsDiv.style.display = 'none';
                return;
            }

            searchTimeout = setTimeout(() => {
                const url = '@Url.Action("GetLinkableTickets")?currentTicketId=@Model.Id&term=' + encodeURIComponent(query);
                fetch(url)
                    .then(response => response.json())
                    .then(data => {
                        resultsDiv.innerHTML = '';
                        if (data.length === 0) {
                            resultsDiv.innerHTML = '<div class="list-group-item small text-muted">No tickets found</div>';
                        } else {
                            data.forEach(item => {
                                const btn = document.createElement('button');
                                btn.type = 'button';
                                btn.className = 'list-group-item list-group-item-action small py-2';
                                btn.textContent = item.text;
                                btn.onclick = () => selectTicket(item.id, item.text);
                                resultsDiv.appendChild(btn);
                            });
                        }
                        resultsDiv.style.display = 'block';
                    });
            }, 300);
        });

        function selectTicket(id, text) {
            selectedIdInput.value = id;
            selectedText.textContent = text;
            selectedDisplay.style.display = 'block';
            resultsDiv.style.display = 'none';
            searchInput.value = '';
            submitBtn.disabled = false;
        }

        // Close results when clicking outside
        document.addEventListener('click', function(e) {
            if (!searchInput.contains(e.target) && !resultsDiv.contains(e.target)) {
                resultsDiv.style.display = 'none';
            }
        });
    </script>
}