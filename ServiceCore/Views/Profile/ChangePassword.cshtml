@{
    ViewData["Title"] = "Change Password";
}

<div class="row justify-content-center py-5">
    <div class="col-md-6 col-lg-5">
        <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
            <div class="card-header bg-dark text-white p-4 text-center">
                <div class="mb-3">
                    <div class="avatar-lg bg-white text-dark rounded-circle d-inline-flex align-items-center justify-content-center fs-2 fw-bold shadow-sm" style="width: 80px; height: 80px;">
                        <i class="bi bi-shield-lock-fill"></i>
                    </div>
                </div>
                <h3 class="fw-bold mb-0">Update Security</h3>
                <p class="opacity-75 small">Secure your account with a new password</p>
            </div>
            <div class="card-body p-4 p-lg-5">
                <form asp-action="ChangePassword" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-4"></div>

                    <div class="mb-4">
                        <label for="currentPassword" class="form-label small fw-bold text-uppercase text-muted">Current Password</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-0"><i class="bi bi-key text-primary"></i></span>
                            <input type="password" id="currentPassword" name="currentPassword" class="form-control bg-light border-0" placeholder="Enter current password" required />
                        </div>
                    </div>

                    <div class="mb-4">
                        <label for="newPassword" class="form-label small fw-bold text-uppercase text-muted">New Password</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-0"><i class="bi bi-shield-plus text-primary"></i></span>
                            <input type="password" id="newPassword" name="newPassword" class="form-control bg-light border-0" placeholder="Enter new password" required />
                        </div>
                        <div class="form-text small opacity-50 mt-2">Using a mix of letters, numbers, and symbols is recommended.</div>
                    </div>

                    <div class="mb-4">
                        <label for="confirmPassword" class="form-label small fw-bold text-uppercase text-muted">Confirm New Password</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-0"><i class="bi bi-shield-check text-primary"></i></span>
                            <input type="password" id="confirmPassword" name="confirmPassword" class="form-control bg-light border-0" placeholder="Confirm new password" required />
                        </div>
                    </div>

                    <div class="d-grid gap-2 mt-5">
                        <button type="submit" class="btn btn-dark btn-lg rounded-pill fw-bold py-3"><i class="bi bi-lock-fill me-2"></i>Update Password</button>
                        <a asp-action="Index" class="btn btn-link text-muted text-decoration-none small">Cancel and Return</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
