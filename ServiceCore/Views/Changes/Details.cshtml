@model ServiceCore.Models.ChangeRequest
@using System.Security.Claims
@{
    ViewData["Title"] = $"Change: {Model.Title}";
}

<div class="container-fluid py-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <div class="d-flex align-items-center gap-2 mb-2">
                <span class="badge bg-brand-blue bg-opacity-10 text-brand-blue border border-brand-blue border-opacity-25">Change Record</span>
                <span class="text-muted fw-bold">#CR-@Model.Id.ToString("D4")</span>
            </div>
            <h1 class="h3 mb-1 fw-bold">@Model.Title</h1>
            <p class="text-muted mb-0"><i class="bi bi-person me-1"></i>Requested by @Model.RequestedBy?.Name on @Model.CreatedAt.ToString("MMM dd, yyyy")</p>
        </div>
        <div class="d-flex gap-2">
            @if (Model.Status == "Draft")
            {
                <form action="@Url.Action("Submit")" method="post">
                    <input type="hidden" name="id" value="@Model.Id" />
                    <button type="submit" class="btn btn-primary shadow-sm px-4">
                        <i class="bi bi-send me-2"></i>Submit for Review
                    </button>
                </form>
            }
            <div class="dropdown">
                <button class="btn btn-outline-secondary dropdown-toggle px-4" type="button" data-bs-toggle="dropdown">
                    Workflow Status
                </button>
                <ul class="dropdown-menu dropdown-menu-end shadow border-0">
                    <li><h6 class="dropdown-header">Move Lifecycle</h6></li>
                    @foreach (var move in new[] { "Under Assessment", "Approved", "Scheduled", "In Progress", "Implemented", "Closed" })
                    {
                        <li>
                            <form action="@Url.Action("UpdateStatus")" method="post">
                                <input type="hidden" name="id" value="@Model.Id" />
                                <input type="hidden" name="status" value="@move" />
                                <button type="submit" class="dropdown-item @(Model.Status == move ? "active" : "")">Move to @move</button>
                            </form>
                        </li>
                    }
                    <li><hr class="dropdown-divider"></li>
                    <li>
                        <form action="@Url.Action("UpdateStatus")" method="post">
                            <input type="hidden" name="id" value="@Model.Id" />
                            <input type="hidden" name="status" value="Rejected" />
                            <button type="submit" class="dropdown-item text-danger">Reject Change</button>
                        </form>
                    </li>
                </ul>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- Main Analysis Content -->
        <div class="col-12 col-xl-8">
            <!-- Assessment Card -->
            <div class="card glass-elevated border-0 shadow-sm mb-4">
                <div class="card-header bg-white py-3 border-0">
                    <h5 class="mb-0 fw-bold"><i class="bi bi-info-circle me-2 text-primary"></i>Assessment & Risk</h5>
                </div>
                <div class="card-body p-4">
                    <div class="row g-4 mb-4">
                        <div class="col-md-3">
                            <label class="small text-muted fw-bold d-block mb-1">TYPE</label>
                            <span class="badge bg-light text-dark border px-3 py-2 fw-bold w-100">@Model.Type</span>
                        </div>
                        <div class="col-md-3">
                            <label class="small text-muted fw-bold d-block mb-1">RISK LEVEL</label>
                            <span class="badge @(Model.RiskLevel == "High" ? "bg-danger" : "bg-info") bg-opacity-10 text-@(Model.RiskLevel == "High" ? "danger" : "info") border px-3 py-2 fw-bold w-100">@Model.RiskLevel</span>
                        </div>
                        <div class="col-md-3">
                            <label class="small text-muted fw-bold d-block mb-1">IMPACT</label>
                            <span class="badge bg-light text-dark border px-3 py-2 fw-bold w-100">@Model.Impact</span>
                        </div>
                        <div class="col-md-3">
                            <label class="small text-muted fw-bold d-block mb-1">PRIORITY</label>
                            <span class="badge @(Model.Priority == "Critical" ? "bg-danger" : "bg-warning") bg-opacity-10 text-@(Model.Priority == "Critical" ? "danger" : "warning") border px-3 py-2 fw-bold w-100">@Model.Priority</span>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="small text-muted fw-bold d-block mb-2">DESCRIPTION</label>
                        <div class="p-4 bg-light rounded-4 border">
                            @Model.Description
                        </div>
                    </div>

                    <div class="row g-4">
                        <div class="col-md-6">
                            <h6 class="fw-bold mb-3"><i class="bi bi-tools me-2 text-primary"></i>Implementation Plan</h6>
                            <div class="p-3 bg-primary bg-opacity-5 rounded border-primary border-opacity-10 border min-h-150 shadow-sm">
                                @(Model.ImplementationPlan ?? "No implementation plan defined.")
                            </div>
                        </div>
                        <div class="col-md-6">
                            <h6 class="fw-bold mb-3"><i class="bi bi-arrow-counterclockwise me-2 text-danger"></i>Rollback Plan</h6>
                            <div class="p-3 bg-danger bg-opacity-5 rounded border-danger border-opacity-10 border min-h-150 shadow-sm">
                                @(Model.RollbackPlan ?? "No rollback plan defined.")
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Tasks Card -->
            <div class="card glass-elevated border-0 shadow-sm mb-4 overflow-hidden">
                <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 fw-bold"><i class="bi bi-check2-square me-2 text-success"></i>Implementation Tasks</h5>
                    <button class="btn btn-sm btn-outline-success" data-bs-toggle="modal" data-bs-target="#addTaskModal">
                        <i class="bi bi-plus-lg"></i> Add Task
                    </button>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0 align-middle">
                            <thead class="bg-light smaller fw-bold text-muted">
                                <tr>
                                    <th class="ps-4">DESCRIPTION</th>
                                    <th>ASSIGNEE</th>
                                    <th>DUE DATE</th>
                                    <th>STATUS</th>
                                    <th class="pe-4 text-end">ACTION</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var task in Model.Tasks)
                                {
                                    <tr>
                                        <td class="ps-4">@task.Description</td>
                                        <td>
                                            <div class="d-flex align-items-center gap-2">
                                                <div class="avatar avatar-xs bg-brand-blue text-primary smaller fw-bold">@(task.AssignedTo?.Name?.Substring(0, 1) ?? "?")</div>
                                                <span class="smaller fw-500">@(task.AssignedTo?.Name ?? "Unassigned")</span>
                                            </div>
                                        </td>
                                        <td class="smaller text-muted">@(task.DueDate?.ToString("g") ?? "N/A")</td>
                                        <td>
                                            <span class="badge @(task.Status == "Completed" ? "bg-success" : "bg-warning") bg-opacity-10 text-@(task.Status == "Completed" ? "success" : "warning") border smaller px-2">@task.Status</span>
                                        </td>
                                        <td class="pe-4 text-end">
                                            @if (task.Status != "Completed")
                                            {
                                                <form action="@Url.Action("CompleteTask")" method="post">
                                                    <input type="hidden" name="taskId" value="@task.Id" />
                                                    <button type="submit" class="btn btn-sm btn-link text-success p-0">Complete</button>
                                                </form>
                                            }
                                        </td>
                                    </tr>
                                }
                                @if (!Model.Tasks.Any())
                                {
                                    <tr>
                                        <td colspan="5" class="text-center py-4 text-muted italic small">No implementation tasks defined for this change.</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Sidebar -->
        <div class="col-12 col-xl-4">
            <!-- Lifecycle Sidebar -->
            <div class="card glass border-0 shadow-sm mb-4 overflow-hidden rounded-4">
                <div class="bg-brand-blue p-4 text-white">
                    <div class="small fw-bold opacity-75 mb-1">CURRENT STATUS</div>
                    <h3 class="fw-bold mb-0">@Model.Status</h3>
                </div>
                <div class="card-body p-4 bg-white">
                    <div class="row g-3 mb-4">
                        <div class="col-6">
                            <div class="p-3 bg-light rounded-4 border text-center">
                                <i class="bi bi-calendar-event d-block mb-1 text-primary"></i>
                                <span class="d-block smaller text-muted fw-bold">START DATE</span>
                                <span class="fw-bold small">@(Model.PlannedStartDate?.ToString("MMM dd") ?? "TBD")</span>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="p-3 bg-light rounded-4 border text-center">
                                <i class="bi bi-calendar-check d-block mb-1 text-success"></i>
                                <span class="d-block smaller text-muted fw-bold">END DATE</span>
                                <span class="fw-bold small">@(Model.PlannedEndDate?.ToString("MMM dd") ?? "TBD")</span>
                            </div>
                        </div>
                    </div>
                    
                    <div class="d-flex align-items-center mb-4">
                        <div class="avatar bg-brand-blue text-primary me-3">
                            <i class="bi bi-shield-lock"></i>
                        </div>
                        <div>
                            <span class="d-block smaller text-muted fw-bold">CHANGE ANALYST</span>
                            <span class="fw-bold">@(Model.AssignedTo?.Name ?? "Unassigned")</span>
                        </div>
                    </div>

                    @if (Model.Status == "Submitted")
                    {
                        <div class="alert alert-warning border-0 shadow-sm py-2 px-3 mb-0">
                            <div class="d-flex align-items-center gap-2 small fw-bold">
                                <i class="bi bi-shield-exclamation fs-5"></i>
                                This change is pending CAB review.
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- Approvals Card -->
            <div class="card glass-elevated border-0 shadow-sm mb-4 overflow-hidden">
                <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                    <h6 class="mb-0 fw-bold"><i class="bi bi-pencil-square me-2 text-primary"></i>Approvals (CAB)</h6>
                    <button class="btn btn-sm btn-link text-primary p-0" data-bs-toggle="modal" data-bs-target="#addApprovalModal">Add Reviewer</button>
                </div>
                <div class="card-body p-0">
                    <div class="list-group list-group-flush">
                        @foreach (var approval in Model.Approvals)
                        {
                            <div class="list-group-item p-3 border-0 border-bottom">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="avatar avatar-xs bg-light text-dark smaller fw-bold">@(approval.Approver?.Name?.Substring(0, 1) ?? "U")</div>
                                        <div class="small fw-bold">@approval.Approver?.Name</div>
                                    </div>
                                    <span class="badge @(approval.Status == "Approved" ? "bg-success" : (approval.Status == "Rejected" ? "bg-danger" : "bg-warning")) bg-opacity-10 text-@(approval.Status == "Approved" ? "success" : (approval.Status == "Rejected" ? "danger" : "warning")) border smaller">@approval.Status</span>
                                </div>
                                @if (approval.Status == "Pending" && approval.ApproverId.ToString() == User.FindFirstValue(ClaimTypes.NameIdentifier))
                                {
                                    <div class="mt-2 text-end">
                                        <button class="btn btn-sm btn-success px-3 me-2" onclick="showApprovalModal(@approval.Id, 'Approved')">Approve</button>
                                        <button class="btn btn-sm btn-outline-danger" onclick="showApprovalModal(@approval.Id, 'Rejected')">Reject</button>
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(approval.Comments))
                                {
                                    <div class="bg-light p-2 rounded small mt-2 italic">"@approval.Comments"</div>
                                }
                            </div>
                        }
                        @if (!Model.Approvals.Any())
                        {
                            <div class="p-4 text-center text-muted small italic">No approval requests generated yet.</div>
                        }
                    </div>
                </div>
            </div>

            <!-- Activity Audit Trail -->
            <div class="card glass shadow-sm border-0 overflow-hidden">
                <div class="card-header bg-white py-3 border-0">
                    <h6 class="mb-0 fw-bold"><i class="bi bi-clock-history me-2"></i>Change Activity Log</h6>
                </div>
                <div class="card-body p-0">
                    <div class="timeline p-4">
                        @foreach (var activity in Model.Activities.OrderByDescending(a => a.CreatedAt))
                        {
                            <div class="mb-4 ps-4 position-relative border-start">
                                <div class="position-absolute start-0 translate-middle-x bg-brand-blue bg-opacity-25 rounded-circle" style="width: 12px; height: 12px; margin-left: -1px;"></div>
                                <div class="d-flex justify-content-between mb-1">
                                    <span class="small fw-bold">@activity.Action</span>
                                    <span class="smaller text-muted">@activity.CreatedAt.ToString("MMM dd, HH:mm")</span>
                                </div>
                                <p class="smaller text-muted mb-1">@activity.Details</p>
                                <div class="smaller fw-bold text-dark">By @activity.User?.Name</div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal: Add Approval -->
<div class="modal fade" id="addApprovalModal" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-brand-blue text-white">
                <h5 class="modal-title fw-bold">Add CAB Reviewer</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form action="@Url.Action("AddApproval")" method="post">
                <input type="hidden" name="changeId" value="@Model.Id" />
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Select Approver</label>
                        <select name="approverId" class="form-select">
                            @foreach (var user in (List<User>)ViewBag.Users)
                            {
                                <option value="@user.Id">@user.Name</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="modal-footer bg-light p-2">
                    <button type="submit" class="btn btn-brand-blue w-100">Request Approval</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal: Action Approval -->
<div class="modal fade" id="actionApprovalModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title fw-bold" id="approvalModalTitle">Decision on Change</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form action="@Url.Action("ActionApproval")" method="post">
                <input type="hidden" name="approvalId" id="modalApprovalId" />
                <input type="hidden" name="status" id="modalApprovalStatus" />
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Feedback / Comments</label>
                        <textarea name="comments" class="form-control" rows="4" placeholder="Enter justification for your decision..."></textarea>
                    </div>
                </div>
                <div class="modal-footer bg-light">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-dark px-4" id="modalApprovalBtn">Confirm Decision</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal: Add Task -->
<div class="modal fade" id="addTaskModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title fw-bold">Add Implementation Task</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form action="@Url.Action("AddTask")" method="post">
                <input type="hidden" name="changeId" value="@Model.Id" />
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Step Description</label>
                        <textarea name="description" class="form-control" rows="3" required></textarea>
                    </div>
                    <div class="row g-3">
                        <div class="col-6">
                            <label class="form-label fw-bold small">Assignee</label>
                            <select name="assignedToId" class="form-select">
                                <option value="">Optional</option>
                                @foreach (var user in (List<User>)ViewBag.Users)
                                {
                                    <option value="@user.Id">@user.Name</option>
                                }
                            </select>
                        </div>
                        <div class="col-6">
                            <label class="form-label fw-bold small">Due Date</label>
                            <input type="datetime-local" name="dueDate" class="form-control" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer bg-light">
                    <button type="submit" class="btn btn-success px-4">Create Task</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function showApprovalModal(id, status) {
            document.getElementById('modalApprovalId').value = id;
            document.getElementById('modalApprovalStatus').value = status;
            document.getElementById('approvalModalTitle').innerText = status + ' Change Request';
            document.getElementById('modalApprovalBtn').className = 'btn px-4 ' + (status === 'Approved' ? 'btn-success' : 'btn-danger');
            new bootstrap.Modal(document.getElementById('actionApprovalModal')).show();
        }
    </script>
}

<style>
    .avatar-xs { width: 24px; height: 24px; border-radius: 50%; display: flex; align-items: center; justify-content: center; }
    .min-h-150 { min-height: 150px; }
    .timeline { position: relative; border-left: 2px solid #f1f1f1; margin: 0; padding: 0; }
</style>
