@model ServiceCore.Models.ChangeRequest
@{
    ViewData["Title"] = "New Change Request";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-8">
            <div class="d-flex align-items-center mb-4">
                <a href="@Url.Action("Index")" class="btn btn-outline-secondary btn-sm me-3 border-0 shadow-sm">
                    <i class="bi bi-arrow-left"></i>
                </a>
                <div>
                    <h1 class="h3 mb-1 fw-bold">Initiate Change Request</h1>
                    <p class="text-muted small mb-0">Formally document and propose modifications to IT assets or services.</p>
                </div>
            </div>

            <div class="card glass-elevated border-0 shadow-sm p-4 overflow-hidden">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    
                    <div class="row g-4">
                        <div class="col-12">
                            <label asp-for="Title" class="form-label small fw-bold text-uppercase text-muted">Change Heading</label>
                            <input asp-for="Title" class="form-control form-control-lg border-2" placeholder="e.g., Firewall Firmware Upgrade - Q3 Patch" />
                            <span asp-validation-for="Title" class="text-danger small"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="Description" class="form-label small fw-bold text-uppercase text-muted">Justification & Scope</label>
                            <textarea asp-for="Description" class="form-control" rows="5" placeholder="Describe why this change is needed and what it will affect..."></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Type" class="form-label small fw-bold text-uppercase text-muted">Change Type</label>
                            <select asp-for="Type" class="form-select border-2">
                                <option value="Standard">Standard (Pre-approved)</option>
                                <option value="Normal">Normal (CAB Review Required)</option>
                                <option value="Emergency">Emergency (Immediate Action)</option>
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="CategoryId" class="form-label small fw-bold text-uppercase text-muted">Category</label>
                            <select asp-for="CategoryId" class="form-select" asp-items="@(new SelectList(ViewBag.Categories, "Id", "Name"))">
                                <option value="">Select Category...</option>
                            </select>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="RiskLevel" class="form-label small fw-bold text-uppercase text-muted">Risk Assessment</label>
                            <select asp-for="RiskLevel" class="form-select">
                                <option value="Low">Low</option>
                                <option value="Medium">Medium</option>
                                <option value="High">High</option>
                                <option value="Critical">Critical</option>
                            </select>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="Impact" class="form-label small fw-bold text-uppercase text-muted">Impact</label>
                            <select asp-for="Impact" class="form-select">
                                <option value="Low">Low</option>
                                <option value="Medium">Medium</option>
                                <option value="High">High</option>
                                <option value="Extensive">Extensive</option>
                            </select>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="Priority" class="form-label small fw-bold text-uppercase text-muted">Priority</label>
                            <select asp-for="Priority" class="form-select">
                                <option value="Low">Low</option>
                                <option value="Medium">Medium</option>
                                <option value="High">High</option>
                                <option value="Critical">Critical</option>
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="PlannedStartDate" class="form-label small fw-bold text-uppercase text-muted">Requested Start Date</label>
                            <input asp-for="PlannedStartDate" class="form-control" type="datetime-local" />
                        </div>

                        <div class="col-md-6">
                            <label asp-for="PlannedEndDate" class="form-label small fw-bold text-uppercase text-muted">Requested End Date</label>
                            <input asp-for="PlannedEndDate" class="form-control" type="datetime-local" />
                        </div>

                        <div class="col-12">
                            <label asp-for="ImplementationPlan" class="form-label small fw-bold text-uppercase text-muted">Implementation Plan</label>
                            <textarea asp-for="ImplementationPlan" class="form-control" rows="3" placeholder="Step-by-step technical plan..."></textarea>
                        </div>

                        <div class="col-12">
                            <label asp-for="RollbackPlan" class="form-label small fw-bold text-uppercase text-muted">Back-out / Rollback Plan</label>
                            <textarea asp-for="RollbackPlan" class="form-control" rows="3" placeholder="Describe how to revert the changes if something goes wrong..."></textarea>
                        </div>

                        <div class="col-12 border-top pt-4 text-end">
                            <a href="@Url.Action("Index")" class="btn btn-outline-secondary px-4 me-2">Cancel</a>
                            <button type="submit" class="btn btn-brand-blue px-5">Create Draft Request</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
